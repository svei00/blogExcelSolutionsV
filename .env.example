# Copy this file to .env and fill in real values. .env is gitignored -
# never commit real secrets (REBUILD_PLAN 3.5).

# MongoDB connection string.
MongoDB=

# Secret used to sign/verify JWT session tokens (api/controllers/auth.controller.js).
# Rotating this invalidates every existing session (everyone gets logged
# out) - that's expected and safe to do periodically, not a bug.
JWT_SECRET=
